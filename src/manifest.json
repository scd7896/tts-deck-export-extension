{
  "manifest_version": 3,
  "name": "TCG Deck Exporter",
  "version": "1.0.0",
  "description": "Tabletop Simulator용 TCG 덱을 추출하는 확장프로그램",

  "action": {
    "default_popup": "popup/index.html"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": ["tabs"],
  "host_permissions": ["https://cookierunbraverse.com/*"],

  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },

  "content_scripts": [
    {
      "matches": ["https://cookierunbraverse.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
